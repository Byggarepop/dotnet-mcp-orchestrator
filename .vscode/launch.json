{
  "version": "0.2.0",
  "configurations": [
    {
      // Attach to the running MCP server (launched by the IDE's MCP host).
      // Start the agent with MCP_ORCHESTRATOR_DEBUG=1 (see README), then run this
      // and pick the "McpOrchestrator" process.
      "name": "Attach to McpOrchestrator",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickProcess}"
    }
  ]
}
