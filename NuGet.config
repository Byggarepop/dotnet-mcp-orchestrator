<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Repo-local package sources. The <clear /> drops sources inherited from the
    user/machine-level NuGet.config (e.g. a 'TokenSaverLocal' feed that belongs to a
    different project and may not exist on this machine), so this project restores from
    nuget.org alone and builds independently.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
